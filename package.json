    "test:unit:coverage": "sfdx-lwc-jest --coverage -- --no-cache"
  },
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.1",
    "@salesforce/sfdx-lwc-jest": "^7.1.2",
    "prettier": "^3.5.3",
    "prettier-plugin-apex": "^2.2.6"
  }
}
